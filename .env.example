# ─── Frontend (prefijo VITE_ → visible en el navegador) ───

# Dejar vacío en Railway (mismo servidor sirve web + API)
VITE_API_URL=

# Link de Calendly para "Reservar llamada"
VITE_CALENDLY_URL=

# (Opcional) Webhook para leads (Zapier/Make)
VITE_LEAD_WEBHOOK_URL=

# Email de contacto (mailto fallback)
VITE_CONTACT_EMAIL=info@theaibusiness.com

# WhatsApp sin + (ej: 34612345678)
VITE_WHATSAPP_NUMBER=376377048

# ─── Supabase (base de datos) ───

# URL del proyecto Supabase (Settings → API → Project URL)
SUPABASE_URL=

# Clave de servicio (Settings → API → service_role secret) — NUNCA exponer en el front
SUPABASE_SERVICE_KEY=

# ─── Backend (solo servidor, NO visibles en navegador) ───

# SendGrid API Key (empieza por SG.)
SENDGRID_API_KEY=

# Email verificado en SendGrid como sender
SENDGRID_FROM_EMAIL=info@theaibusiness.com

# Nombre del remitente
SENDGRID_FROM_NAME=The AI Business

# Email para recibir notificaciones de leads y contactos
NOTIFY_EMAIL=info@theaibusiness.com

# Calendly URL para los CTAs dentro de los emails
CALENDLY_URL=

# (Opcional) Webhook del servidor al recibir un lead (Zapier/Make/CRM)
LEAD_WEBHOOK_URL=

# Puerto (Railway lo asigna automáticamente)
PORT=3000
